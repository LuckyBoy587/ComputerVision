   "source": [
    "def compute_rnn_hidden_state(x, h_prev, Wx, Wh, b):\n",
    "    return Wx * x + Wh * h_prev + b"
   ],
   "outputs": [],
   "execution_count": null
  },
  {
   "cell_type": "code",
   "metadata": {},
   "source": [
    "ht = compute_rnn_hidden_state(xt, h_prev, Wx, Wh, b)\n",
    "print(f\"Hidden state h_t = {ht:.1f}\")"
